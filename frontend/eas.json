{
  "cli": {
    "version": ">= 16.4.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "gradleCommand": ":app:assembleDebug",
        "env": {
          "EXPO_USE_GRADLE_VERSION_CATALOG": "1"
        }
      }
    },
    "preview": {
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease",
        "env": {
          "EXPO_PUBLIC_API_BASE_URL": "http://117.251.19.107/api",
          "EXPO_USE_GRADLE_VERSION_CATALOG": "1"
        }
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle",
        "gradleCommand": ":app:bundleRelease",
        "env": {
          "EXPO_PUBLIC_API_BASE_URL": "https://ocfa.onrender.com/api",
          "EXPO_USE_GRADLE_VERSION_CATALOG": "1"
        }
      }
    }
  },
  "submit": {
    "production": {}
  }
}